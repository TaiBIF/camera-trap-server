# Slack app credentials (Socket Mode)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Path inside the container where cameratrap.duckdb is mounted.
DUCKDB_PATH=/data/cameratrap.duckdb

# Comma-separated Slack channel IDs (e.g. C0123456789,C0987654321).
# If set, /ct-* commands only work in these channels. Leave blank for any-channel.
ALLOWED_CHANNEL_IDS=

# Natural-language querying (/ct-ask).
ANTHROPIC_API_KEY=
# Optional: claude-sonnet-4-6 (default) or claude-opus-4-7
ANTHROPIC_MODEL=

# Optional: default project scope for /ct-ask. When set, questions are
# automatically filtered to this project_id unless the user asks about
# another project or a cross-project question.
DEFAULT_PROJECT_ID=
